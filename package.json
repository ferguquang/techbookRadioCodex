{
  "name": "techbook-radio-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "node scripts/render-with-voice.mjs --episode=content/episode.sample.json --output=out/techbook-short.mp4",
    "render:episode": "node scripts/render-with-voice.mjs",
    "render:raw": "remotion render src/index.ts TechbookShorts out/techbook-short.mp4 --props=content/episode.sample.json",
    "new:episode": "node scripts/new-episode.mjs",
    "voice": "node scripts/generate-voice.mjs",
    "voice:demo": "node scripts/generate-voice-demo.mjs",
    "voice:episode": "node scripts/prepare-episode-audio.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.477",
    "@remotion/renderer": "4.0.477",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.477"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}
